# Most runtime config lives in configs/settings.yaml; this file covers
# secrets and Docker-only overrides.

GEMINI_API_KEY=your-key-here

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_products
ELASTICSEARCH_URL=http://localhost:9200
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
GRPC_PORT=50052
HTTP_PORT=8000

# Service discovery. Leave REGISTRY_URL unset to run standalone (e.g. local
# dev). SERVICE_HOST is what other services should dial - the docker-compose
# service name in that environment.
REGISTRY_URL=http://service-registry:8500
SERVICE_NAME=rag-recommend
SERVICE_HOST=rag-recommend
