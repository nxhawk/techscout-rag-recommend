{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "type": "dashboard",
        "name": "Annotations & Alerts",
        "enable": true,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        }
      }
